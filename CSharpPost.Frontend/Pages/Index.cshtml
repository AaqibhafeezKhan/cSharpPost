    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s;
}

.pagination-button:hover {
    background: #512e74;
}

.pagination-info {
    color: #666;
}

.loading, .no-data, .loading-posts {
    text-align: center;
    color: #666;
    font-style: italic;
}

@media (max-width: 768px) {
    .content-grid {
        grid-template-columns: 1fr;
    }
    
    .header-content {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
    }
    
    .timeline-controls {
        flex-direction: column;
    }
    
    .search-container {
        flex-direction: column;
    }
}

    
